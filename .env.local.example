# Copie para .env.local e preencha. NUNCA versione o .env.local (já está no .gitignore).

# Supabase (Project Settings -> Data API)
SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxxxx

# Senha de acesso ao /dashboard
DASHBOARD_PASSWORD=troque-esta-senha

# Z-API (https://app.z-api.io) — aviso de novo lead no WhatsApp do comercial
ZAPI_INSTANCE_ID=sua-instance-id
ZAPI_INSTANCE_TOKEN=seu-instance-token
ZAPI_CLIENT_TOKEN=seu-account-security-token
# Número que recebe o aviso (só dígitos, com DDD; código do país é opcional)
ZAPI_NOTIFY_PHONE=5532990233390
